# =============================================================================
# RxSentinel — 定制化 .gitignore
# 结构：Python 后端 + MediaCrawler 爬虫 + Vue 前端 + Streamlit WebUI
# =============================================================================


# -----------------------------------------------------------------------------
# 敏感配置
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
# 注意：.env.example 应当提交，作为配置模板


# -----------------------------------------------------------------------------
# 核心数据目录
# -----------------------------------------------------------------------------
MediaCrawler/data/
ProcessCdata/data/
SentinelDashboard/public/*.jsonl

# MediaCrawler 浏览器运行时数据（登录态 cookie、CDP 缓存等）
MediaCrawler/browser_data/
**/cdp_*_user_data_dir/

# MediaCrawler SQLite 本地数据库
MediaCrawler/database/*.db

# -----------------------------------------------------------------------------
# 运行时日志 & 临时文件
# -----------------------------------------------------------------------------
sentinel_api.log
**/logs/
# 过滤日志文件（filter_log.txt、ai_extract_log.txt 等 ProcessCdata 产物）
ProcessCdata/**/*_log.txt
ProcessCdata/**/*.png

# -----------------------------------------------------------------------------
# Python 字节码 & 缓存
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.cache/
.pytest_cache/
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# -----------------------------------------------------------------------------
# Python 虚拟环境（本项目用 conda，但也兼容 venv）
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/

# -----------------------------------------------------------------------------
# 测试 & 覆盖率产物
# -----------------------------------------------------------------------------
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
# 压测报告（可随时重跑生成）
tests/benchmarks/*.json

# -----------------------------------------------------------------------------
# 前端 (SentinelDashboard — Vue 3 + Vite)
# -----------------------------------------------------------------------------
node_modules/
SentinelDashboard/dist/
# Vite 构建缓存（本地生成，不同机器可能不兼容）
SentinelDashboard/.vite/

# MediaCrawler 也有前端依赖
MediaCrawler/node_modules/

# -----------------------------------------------------------------------------
# IDE & 编辑器
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.iml

# -----------------------------------------------------------------------------
# 操作系统产物
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Playwright（MediaCrawler 使用）
# -----------------------------------------------------------------------------
.playwright/

# -----------------------------------------------------------------------------
# 其他项目内部约定目录
# -----------------------------------------------------------------------------
agent_zone/
debug_tools/
/temp_image/
.refer/
