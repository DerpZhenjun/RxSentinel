# =============================================================================
# RxSentinel 环境配置模板
# =============================================================================
# 使用流程：
#   1. 将本文件复制一份，重命名为 .env（在项目根目录）
#      cp .env.example .env          (Linux / macOS)
#      copy .env.example .env        (Windows CMD)
#   2. 按下方说明填写各项配置
#   3. .env 已加入 .gitignore，不会被提交到 Git，请勿手动提交
# =============================================================================


# -----------------------------------------------------------------------------
# MongoDB 数据库
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=Oestrogen
MONGODB_COLLECTION=sentinel_leads


# -----------------------------------------------------------------------------
# 后端 API 服务
# -----------------------------------------------------------------------------
SENTINEL_API_HOST=127.0.0.1
SENTINEL_API_PORT=8000

# API 鉴权密钥（Bearer Token）
# ─ 作用：保护情报数据接口，防止未授权访问
# ─ 留空 = 开发免鉴权模式（本地调试时可留空）
# ─ 生产部署时务必设置！
#
# 生成随机密钥（在终端运行）：
#   Windows PowerShell : python -c "import secrets; print(secrets.token_hex(32))"
#   Linux / macOS      : python3 -c "import secrets; print(secrets.token_hex(32))"
#
# 将生成的字符串粘贴到等号右侧，同时复制到 SentinelDashboard/.env 的 VITE_API_SECRET
API_SECRET_KEY=


# -----------------------------------------------------------------------------
# 前端大屏（Vite，仅 VITE_ 前缀的变量会暴露给浏览器）
# ─ 注意：这些变量需要写在 SentinelDashboard/.env，不是项目根目录的 .env
# ─ SentinelDashboard/.env 文件不存在时需要手动创建：
#     cd SentinelDashboard
#     copy .env.example .env          (Windows CMD)
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://127.0.0.1:8000

# 与后端 API_SECRET_KEY 填写相同的值
VITE_API_SECRET=
