# SentinelDashboard 前端环境配置模板
# 使用流程：
#   1. 将本文件复制为 .env（在 SentinelDashboard 目录下）
#   2. 填写下方变量
#   3. 重启前端开发服务器（npm run dev）使配置生效

# 后端 API 地址
VITE_API_BASE_URL=http://127.0.0.1:8000

# API 鉴权密钥，必须与项目根目录 .env 中的 API_SECRET_KEY 完全一致
# 留空表示无鉴权（对应后端开发免鉴权模式）
VITE_API_SECRET=

# 验证集 /「大屏合并 → 只存入本地」时合并结果只写入 public/extracted_channels.jsonl，不写 Mongo。
# 大屏默认优先请求 Mongo API，会与本地 JSONL 不一致。设为 true 则首选用 JSONL（与管线产物对齐）。
# 正式环境要对齐仪表盘与库：改用合并「同时入库和存入本地」，或保持 false 并依赖 API。
VITE_USE_JSONL_FIRST=false

# GitHub Pages 静态演示：`npm run build` 使用 `.env.production`（VITE_USE_JSONL_FIRST=true），
# 数据来自 public/extracted_channels.jsonl。详见 README「静态演示部署」。
